# Single-password gate (middleware). Required for Phase 1.
APP_PASSWORD=

# Neon Postgres connection string. Required from Phase 2.
DATABASE_URL=

# Finnhub market data API key (free tier). Required from Phase 3.
FINNHUB_API_KEY=

# kie.ai chat completions. Required from Phase 5.
KIE_API_KEY=
KIE_MODEL=

# Resend email digest. Required from Phase 5.
RESEND_API_KEY=

# eToro public API (from www.etoro.com/settings/trade -> API Key Management).
# Both are required: sent as x-api-key and x-user-key headers.
ETORO_API_KEY=
ETORO_USER_KEY=
