generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum StrategyFit {
  GOOD
  MODERATE
  POOR
}

model WatchlistItem {
  id                String       @id @default(cuid())
  symbol            String       @unique
  name              String
  sector            String?
  notes             String?
  active            Boolean      @default(true)
  yoyoScore         Float?
  yoyoScoreAt       DateTime?
  strategyFit       StrategyFit?
  strategyFitManual Boolean      @default(false)
  // eToro numeric instrument ID; set by the eToro sync. When present, the signals
  // cron pulls daily candles from eToro (full OHLCV + backfill) instead of Finnhub.
  etoroInstrumentId Int?
  addedAt           DateTime     @default(now())

  signals   Signal[]
  trades    Trade[]
  priceBars PriceBar[]

  @@index([active])
}

model PriceBar {
  id     String   @id @default(cuid())
  symbol String
  date   DateTime @db.Date
  open   Float
  high   Float
  low    Float
  close  Float
  // Nullable: bars come from Finnhub's free /quote endpoint (no candle access), which doesn't report volume.
  volume BigInt?

  watchlistItem WatchlistItem @relation(fields: [symbol], references: [symbol], onDelete: Cascade)

  @@unique([symbol, date])
}

enum SignalType {
  BUY
  SHORT
}

model Signal {
  id                String     @id @default(cuid())
  symbol            String
  date              DateTime   @db.Date
  type              SignalType
  streakLength      Int
  cumulativeMovePct Float
  aiCommentary      String?
  createdAt         DateTime   @default(now())

  watchlistItem WatchlistItem @relation(fields: [symbol], references: [symbol], onDelete: Cascade)
  trades        Trade[]

  @@unique([symbol, date, type])
}

enum TradeDirection {
  LONG
  SHORT
}

enum TradeStatus {
  OPEN
  CLOSED
}

model Trade {
  id         String         @id @default(cuid())
  symbol     String
  direction  TradeDirection
  entryPrice Float
  quantity   Float
  entryDate  DateTime       @db.Date
  exitPrice  Float?
  exitDate   DateTime?      @db.Date
  exitReason String?
  notes      String?
  status     TradeStatus    @default(OPEN)
  realizedPL Float?
  signalId   String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  watchlistItem WatchlistItem @relation(fields: [symbol], references: [symbol], onDelete: Cascade)
  signal        Signal?       @relation(fields: [signalId], references: [id], onDelete: SetNull)

  @@index([status])
}

model Settings {
  id               Int      @id @default(1)
  positionSizeUsd  Float    @default(500)
  maxOpenPositions Int      @default(5)
  minSignalMovePct Float    @default(3.0)
  kieModel         String   @default("")
  updatedAt        DateTime @updatedAt
}

// Mirror of the live eToro portfolio, replaced wholesale on each sync.
// Kept separate from Trade so eToro holdings don't pollute signal performance stats.
model EtoroPosition {
  id            String   @id @default(cuid())
  // eToro position IDs exceed int4, and BigInt doesn't survive Next.js serialization — store as text.
  positionId    String   @unique
  instrumentId  Int
  symbol        String
  name          String
  isBuy         Boolean
  leverage      Float
  openRate      Float
  units         Float
  investedUsd   Float
  currentRate   Float?
  unrealizedPnl Float?
  openedAt      DateTime
  syncedAt      DateTime
}

// Single-row account summary from the last eToro sync.
model EtoroAccount {
  id            Int      @id @default(1)
  credit        Float
  unrealizedPnl Float
  syncedAt      DateTime @updatedAt
}

model ChatMessage {
  id        String   @id @default(cuid())
  role      String
  content   String
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  body      String
  read      Boolean  @default(false)
  signalId  String?
  createdAt DateTime @default(now())

  @@index([read])
}
