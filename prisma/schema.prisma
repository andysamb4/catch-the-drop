generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum StrategyFit {
  GOOD
  MODERATE
  POOR
}

model WatchlistItem {
  id                String       @id @default(cuid())
  symbol            String       @unique
  name              String
  sector            String?
  notes             String?
  active            Boolean      @default(true)
  yoyoScore         Float?
  yoyoScoreAt       DateTime?
  strategyFit       StrategyFit?
  strategyFitManual Boolean      @default(false)
  // eToro numeric instrument ID; set by the eToro sync. When present, the signals
  // cron pulls daily candles from eToro (full OHLCV + backfill) instead of Finnhub.
  etoroInstrumentId Int?
  // Set on every scan attempt, even skips and errors. Home page compares this across
  // tickers to surface scans that died partway (timeout, crash, interrupted run).
  lastScannedAt     DateTime?
  addedAt           DateTime     @default(now())

  signals   Signal[]
  trades    Trade[]
  priceBars PriceBar[]

  @@index([active])
}

model PriceBar {
  id     String   @id @default(cuid())
  symbol String
  date   DateTime @db.Date
  open   Float
  high   Float
  low    Float
  close  Float
  // Nullable: bars come from Finnhub's free /quote endpoint (no candle access), which doesn't report volume.
  volume BigInt?

  watchlistItem WatchlistItem @relation(fields: [symbol], references: [symbol], onDelete: Cascade)

  @@unique([symbol, date])
}

enum SignalType {
  BUY
  SHORT
}

model Signal {
  id                String     @id @default(cuid())
  symbol            String
  date              DateTime   @db.Date
  type              SignalType
  streakLength      Int
  cumulativeMovePct Float
  aiCommentary      String?
  createdAt         DateTime   @default(now())

  watchlistItem WatchlistItem @relation(fields: [symbol], references: [symbol], onDelete: Cascade)
  trades        Trade[]
  botPositions  BotPosition[]

  @@unique([symbol, date, type])
}

enum TradeDirection {
  LONG
  SHORT
}

enum TradeStatus {
  OPEN
  CLOSED
}

model Trade {
  id         String         @id @default(cuid())
  symbol     String
  direction  TradeDirection
  entryPrice Float
  quantity   Float
  entryDate  DateTime       @db.Date
  exitPrice  Float?
  exitDate   DateTime?      @db.Date
  exitReason String?
  notes      String?
  status     TradeStatus    @default(OPEN)
  realizedPL Float?
  signalId   String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  watchlistItem WatchlistItem @relation(fields: [symbol], references: [symbol], onDelete: Cascade)
  signal        Signal?       @relation(fields: [signalId], references: [id], onDelete: SetNull)

  @@index([status])
}

enum BotPositionStatus {
  PENDING // order sent to eToro, fill not yet confirmed
  OPEN    // position confirmed open on eToro
  CLOSED  // no longer in eToro's open list; realized P&L recorded from trade history
  FAILED  // order rejected, or never produced a position
}

// A position the auto-trader opened (or tried to) — one row per order attempt.
// `mode` separates demo and real records so the sandbox page can stay demo-only.
// eToro closes positions server-side via the take-profit attached to the order;
// the trade-sync reconcile poll moves rows OPEN -> CLOSED when they leave the
// open-positions list, pulling realized P&L from eToro's trade history.
model BotPosition {
  id             String            @id @default(cuid())
  mode           String // "demo" | "real"
  symbol         String
  instrumentId   Int
  direction      TradeDirection
  status         BotPositionStatus @default(PENDING)
  // eToro order/position IDs exceed int4 and BigInt doesn't survive Next.js
  // serialization — stored as text, same as EtoroPosition.positionId.
  orderId        String?
  positionId     String?           @unique
  requestedUsd   Float
  entryPrice     Float? // actual fill rate reported by eToro
  units          Float?
  takeProfitRate Float? // attached at order time from the signal close, corrected to the fill price post-fill
  stopLossRate   Float? // unused until STOP_LOSS_PCT is enabled
  realizedPnl    Float?
  closeRate      Float?
  closeReason    String? // "take-profit" | "manual" | "unknown" — inferred, eToro history has no explicit reason field
  error          String?
  signalId       String?
  openedAt       DateTime          @default(now())
  filledAt       DateTime?
  closedAt       DateTime?
  updatedAt      DateTime          @updatedAt

  signal Signal? @relation(fields: [signalId], references: [id], onDelete: SetNull)

  @@index([mode, status])
}

// Append-only auto-trader log: signal decisions, every order request/response
// (with raw eToro payloads), fills, closes, reconcile polls, and errors.
model BotEvent {
  id        String   @id @default(cuid())
  mode      String // "demo" | "real"
  type      String // SIGNAL | ORDER_PLACED | ORDER_REJECTED | ORDER_BLOCKED | ORDER_SKIPPED | ORDER_FILLED | POSITION_CLOSED | POLL | ERROR
  symbol    String?
  message   String
  payload   Json?
  createdAt DateTime @default(now())

  @@index([mode, createdAt])
}

model Settings {
  id               Int      @id @default(1)
  positionSizeUsd  Float    @default(500)
  maxOpenPositions Int      @default(5)
  minSignalMovePct Float    @default(3.0)
  kieModel         String   @default("")
  updatedAt        DateTime @updatedAt
}

// Mirror of the live eToro portfolio, replaced wholesale on each sync.
// Kept separate from Trade so eToro holdings don't pollute signal performance stats.
model EtoroPosition {
  id            String   @id @default(cuid())
  // eToro position IDs exceed int4, and BigInt doesn't survive Next.js serialization — store as text.
  positionId    String   @unique
  instrumentId  Int
  symbol        String
  name          String
  isBuy         Boolean
  leverage      Float
  openRate      Float
  units         Float
  investedUsd   Float
  currentRate   Float?
  unrealizedPnl Float?
  openedAt      DateTime
  syncedAt      DateTime
}

// Single-row account summary from the last eToro sync.
model EtoroAccount {
  id            Int      @id @default(1)
  credit        Float
  unrealizedPnl Float
  syncedAt      DateTime @updatedAt
}

model ChatMessage {
  id        String   @id @default(cuid())
  role      String
  content   String
  createdAt DateTime @default(now())
}

// Overnight macro warning, written by the morning-brief cron only when the LLM
// judges the night's headlines to be market-moving (war, rate shock, credit
// event, crash). Quiet days produce no row — presence of a recent row IS the
// warning, so the UI never has to grade severity itself.
model MarketAlert {
  id           String   @id @default(cuid())
  date         DateTime @unique @db.Date
  headline     String
  body         String
  // VIX snapshot at generation time, for "how scared is the market actually"
  // context next to the headline. Null if the Yahoo fetch failed.
  vix          Float?
  vixChangePct Float?
  createdAt    DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  body      String
  read      Boolean  @default(false)
  signalId  String?
  createdAt DateTime @default(now())

  @@index([read])
}
